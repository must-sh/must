
extern fn print(x: int);

struct Point {
    x: int,
    y: int,
}

fn square(x: int) -> int {
    x * x
}

fn distance(p: Point) -> int {
    square(p.x) + square(p.y)
}

fn modify(p: *mut Point) {
    (*p).x = (*p).y - 1
}

fn swap(x: *mut Point, y: *mut Point) {
    let tmp = *x in
    *x = *y;
    *y = tmp
}

fn make_zero() -> Point {
    Point .{ x = 0, y = 0 }
}

fn main() {
    let mut p = make_zero() in
    let mut x = p in
    p.x = 3;
    p.y = 4;
    swap(&x, &p);
    print(p.x);
    print(p.y);
    print(x.x);
    print(x.y)
}
