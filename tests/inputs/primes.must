
extern fn print(x: int);
extern fn read() -> int;

fn square(x: int) -> int {
    x * x
}

fn is_prime(x: int) -> bool {
    let mut res = true in
    let mut n = 2 in
    while square(n) < x + 1 {
        if (x / n) * n == x {
            res = false
        };
        n = n + 1
    };
    res
}

fn main() {
    let mut i = 2 in
    while i < 30 {
        if is_prime(i) { print(i) };
        i = i + 1
    }
}
